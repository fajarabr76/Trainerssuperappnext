{
  "name": "trainers-superapp-internal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "next build",
    "test:sidak": "vitest run tests/sidak tests/access-control",
    "test:sidak:watch": "vitest tests/sidak tests/access-control",
    "backup:supabase": "bash scripts/backup-supabase.sh",
    "backup:supabase:storage": "node scripts/backup-supabase-storage.mjs",
    "backup:supabase:all": "npm run backup:supabase && npm run backup:supabase:storage",
    "telefun:dev": "npm --prefix apps/telefun-server run dev",
    "telefun:build": "npm --prefix apps/telefun-server run build",
    "telefun:start": "npm --prefix apps/telefun-server run start"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "@vercel/speed-insights": "^2.0.0",
    "browser-image-compression": "^2.0.2",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "framer-motion": "^12.23.24",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.475.0",
    "motion": "^12.4.2",
    "next": "15.1.11",
    "next-themes": "^0.4.6",
    "pptxgenjs": "^4.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.7",
    "@types/node": "^20.17.19",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.1.11",
    "postcss": "^8.5.2",
    "tailwindcss": "^4.0.7",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
